<!DOCTYPE html>
<html lang="th">

<head>

<meta charset="UTF-8">

<title>Mini Tour Trip One Day</title>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=Playfair+Display:wght@600&display=swap" rel="stylesheet">

<style>

body{

margin:0;
background:#f5f2eb;
font-family:'Cormorant Garamond',serif;
color:#222;

}

header{

height:75vh;

background:url("https://images.unsplash.com/photo-1500530855697-b586d89ba3ee") center/cover;

display:flex;

justify-content:center;

align-items:center;

color:white;

text-align:center;

}

header h1{

font-size:65px;

letter-spacing:4px;

text-shadow:2px 2px 10px black;

}

.container{

width:90%;

margin:auto;

}

.card{

display:flex;

margin:40px 0;

background:white;

box-shadow:0 8px 20px rgba(0,0,0,.15);

border-radius:18px;

overflow:hidden;

}

.card img{

width:360px;

height:260px;

object-fit:cover;

}

.content{

padding:25px;

}

.content h2{

font-family:'Playfair Display',serif;

margin-top:0;

}

.type{

color:#8B4513;

font-weight:bold;

}

.btn{

display:inline-block;

margin-top:15px;

padding:12px 24px;

background:#8B4513;

color:white;

text-decoration:none;

border-radius:30px;

transition:.3s;

}

.btn:hover{

background:black;

}

.map-title{

text-align:center;

font-size:42px;

margin-top:60px;

}

footer{

padding:50px;

}

</style>

</head>

<body>

<header>

<div>

<h1>Mini Tour Trip</h1>

<h2>One Day in Bangkok</h2>

<a class="btn"
href="https://www.google.com/maps/dir/13.762563149770429,100.49782640288294/13.966418124364987,100.66727666606947/16.4898988,99.5160818/13.978770158375152,100.6688220310735/13.988801737195503,100.67685719513622/13.961670357339512,100.68143872974426"
target="_blank">

Explore Route

</a>

</div>

</header>

<div class="container">

{% for p in places %}

<div class="card">

<img src="{{p.image}}">

<div class="content">

<div class="type">{{p.type}}</div>

<h2>{{p.name}}</h2>

<p>{{p.description}}</p>

<a class="btn"
target="_blank"
href="https://www.google.com/maps/search/?api=1&query={{p.lat}},{{p.lon}}">
ข้อมูลเส้นทาง
</a>

</div>

</div>

{% endfor %}

<h2 class="map-title">

Interactive Route Map

</h2>

{{ map_html|safe }}

</div>

<footer></footer>

</body>

</html>
